      {
        "key": "density",
        "label_ja": "密度",
        "description": "流体密度",
        "standard_unit": "kg/m^3",
        "allowed_units": [
          "kg/m^3",
          "g/cm^3"
        ],
        "positive_only": true,
        "nonzero": true,
        "suggested_property_key": "density"
      },
      {
        "key": "velocity",
        "label_ja": "流速",
        "description": "代表流速",
        "standard_unit": "m/s",
        "allowed_units": [
          "m/s"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "diameter",
        "label_ja": "代表長さ",
        "description": "通常は管内径",
        "standard_unit": "m",
        "allowed_units": [
          "m",
          "mm",
          "cm",
          "inch",
          "ft"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "viscosity",
        "label_ja": "粘度",
        "description": "動粘度ではなく粘度",
        "standard_unit": "Pas",
        "allowed_units": [
          "Pas",
          "mPas",
          "cP"
        ],
        "positive_only": true,
        "nonzero": true,
        "suggested_property_key": "viscosity"
      }
    ],
    "outputs": [
      {
        "key": "reynolds_number",
        "label_ja": "Reynolds数",
        "description": "無次元のReynolds数",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "density": "密度 rho",
      "velocity": "流速 v",
      "diameter": "代表長さ D",
      "viscosity": "粘度 mu",
      "reynolds_number": "Reynolds数 Re"
    },
    "applicability": [
      "管内流れの概算",
      "相関式選定の前処理"
    ],
    "assumptions": [
      "単相流の代表値",
      "物性一定近似"
    ],
    "cautions": [
      "非Newton流体では別式検討",
      "二相流にはそのまま適用しない"
    ],
    "references": [
      "化学工学便覧レベルの基礎式"
    ],
    "function_name": "reynolds_number",
    "keywords": [
      "Re",
      "レイノルズ数"
    ],
    "interpretation_hint": "一般に管内では Re < 2300 で層流、Re > 4000 で乱流の目安です。"
  },
  {
    "formula_id": "fluid_froude_number",
    "name_ja": "Froude数",
    "category": "流体",
    "summary": "慣性力と重力の比を評価します。",
    "description": "自由表面流れや液面挙動の概算で使う無次元数です。重力支配か慣性支配かの目安になります。",
    "equation_latex": "Fr = v / sqrt(g L)",
    "inputs": [
      {
        "key": "velocity",
        "label_ja": "流速",
        "description": "代表流速",
        "standard_unit": "m/s",
        "allowed_units": [
          "m/s"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "characteristic_length",
        "label_ja": "代表長さ",
        "description": "液深や代表寸法",
        "standard_unit": "m",
        "allowed_units": [
          "m",
          "mm",
          "cm",
          "ft"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "froude_number",
        "label_ja": "Froude数",
        "description": "無次元のFroude数",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "velocity": "流速 v",
      "characteristic_length": "代表長さ L",
      "froude_number": "Froude数 Fr"
    },
    "applicability": [
      "自由表面流",
      "液面の概算評価"
    ],
    "assumptions": [
      "重力加速度一定",
      "代表長さで近似"
    ],
    "cautions": [
      "密閉配管の通常設計では優先度低め"
    ],
    "references": [
      "流体力学の基礎式"
    ],
    "function_name": "froude_number",
    "keywords": [
      "Fr",
      "自由表面"
    ],
    "interpretation_hint": "Fr が大きいほど慣性支配、小さいほど重力支配の傾向です。"
  },

[
  {
    "formula_id": "fluid_average_velocity",
    "name_ja": "平均流速",
    "category": "流体",
    "summary": "流量と断面積から平均流速を求めます。",
    "description": "配管やダクトの平均流速を計算する最も基本的な式です。圧力損失やReynolds数の前処理によく使います。",
    "equation_latex": "v = Q / A",
    "inputs": [
      {
        "key": "volumetric_flow",
        "label_ja": "体積流量",
        "description": "流れる流体の体積流量",
        "standard_unit": "m^3/s",
        "allowed_units": [
          "m^3/s",
          "m^3/h",
          "L/min"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "area",
        "label_ja": "断面積",
        "description": "流路断面積",
        "standard_unit": "m^2",
        "allowed_units": [
          "m^2",
          "cm^2"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "velocity",
        "label_ja": "平均流速",
        "description": "断面平均流速",
        "standard_unit": "m/s",
        "allowed_units": [
          "m/s"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "volumetric_flow": "体積流量 Q",
      "area": "断面積 A",
      "velocity": "平均流速 v"
    },
    "applicability": [
      "定常流れの概算",
      "断面平均値を使う場面"
    ],
    "assumptions": [
      "断面内で平均化する",
      "圧縮性の影響は別途考慮"
    ],
    "cautions": [
      "局所最大流速ではありません",
      "脈動流では代表値に注意"
    ],
    "references": [
      "化学工学便覧レベルの基礎式"
    ],
    "function_name": "average_velocity",
    "keywords": [
      "流速",
      "流量",
      "断面積"
    ],
    "interpretation_hint": "得られた流速はReynolds数や動圧の計算にそのまま利用できます。"
  },
  {
    "formula_id": "fluid_reynolds_number",
    "name_ja": "Reynolds数",
    "category": "流体",
    "summary": "流れの層流・乱流の目安を求めます。",
    "description": "慣性力と粘性力の比を表す無次元数です。管内流れでは摩擦係数や伝熱相関の選定に使います。",
    "equation_latex": "Re = rho v D / mu",

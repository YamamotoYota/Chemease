[
  {
    "formula_id": "mass_peclet_number",
    "name_ja": "Peclet数",
    "category": "物質移動",
    "summary": "移流と拡散の比を表す物質移動 Peclet数を求めます。",
    "description": "移流と拡散の比を表す物質移動 Peclet数を求めます。 改訂六版 化学工学便覧の移動現象・拡散関連節をもとにした便覧レベルの概算式です。",
    "equation_latex": "Pe = u L / D",
    "inputs": [
      {
        "key": "velocity",
        "label_ja": "流速",
        "description": "代表流速",
        "standard_unit": "m/s",
        "allowed_units": [
          "m/s"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "characteristic_length",
        "label_ja": "代表長さ",
        "description": "拡散距離の代表長さ",
        "standard_unit": "m",
        "allowed_units": [
          "m",
          "mm",
          "cm"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "diffusivity",
        "label_ja": "拡散係数",
        "description": "分子拡散係数",
        "standard_unit": "m^2/s",
        "allowed_units": [
          "m^2/s"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "peclet_number",
        "label_ja": "Peclet数",
        "description": "物質移動の Peclet数",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "velocity": "流速",
      "characteristic_length": "代表長さ",
      "diffusivity": "拡散係数",
      "peclet_number": "Peclet数"
    },
    "applicability": [
      "吸収・蒸発・拡散の概算",
      "二重境膜モデルや無次元整理の初期検討"
    ],
    "assumptions": [
      "代表物性を用いる",
      "平衡関係や流れ場は別途仮定する"
    ],
    "cautions": [
      "強い非理想系では平衡関係を再確認する",
      "詳細設計では個別相関式を参照する"
    ],
    "references": [
      "改訂六版 化学工学便覧 第2章 移動現象",
      "改訂六版 化学工学便覧 物質移動関連節"
    ],
    "function_name": "mass_peclet_number",
    "keywords": [
      "Peclet数",
      "Pe"
    ],
    "interpretation_hint": "移流支配か拡散支配かの目安です。"
  },

        "description": "軽キーの缶出液モル分率",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction",
          "mol%"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "relative_volatility",
        "label_ja": "相対揮発度",
        "description": "代表相対揮発度",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "theoretical_stages",
        "label_ja": "理論段数",
        "description": "最小理論段数の概算",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "x_distillate": "留出液組成 xD",
      "x_bottom": "缶出液組成 xB",
      "relative_volatility": "相対揮発度 alpha",
      "theoretical_stages": "理論段数 N"
    },
    "applicability": [
      "二成分蒸留の概算"
    ],
    "assumptions": [
      "相対揮発度一定",
      "全還流に近い指標"
    ],
    "cautions": [
      "実運転段数ではありません"
    ],
    "references": [

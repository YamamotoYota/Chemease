[
  {
    "formula_id": "sep_relative_volatility",
    "name_ja": "相対揮発度",
    "category": "蒸留・分離",
    "summary": "軽キーと重キーの揮発しやすさの比を求めます。",
    "description": "二成分蒸留のしやすさを示す代表指標です。値が大きいほど分離しやすい傾向です。",
    "equation_latex": "alpha = K_L / K_H",
    "inputs": [
      {
        "key": "k_light",
        "label_ja": "軽キーK値",
        "description": "軽キー成分のK値",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "k_heavy",
        "label_ja": "重キーK値",
        "description": "重キー成分のK値",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "relative_volatility",
        "label_ja": "相対揮発度",
        "description": "軽キー/重キーの比",
        "standard_unit": "fraction",
        "allowed_units": [
          "fraction"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "k_light": "軽キーK値",
      "k_heavy": "重キーK値",
      "relative_volatility": "相対揮発度 alpha"
    },
    "applicability": [
      "二成分分離の概算"
    ],
    "assumptions": [
      "代表K値で近似"
    ],
    "cautions": [
      "組成・温度で変化します"
    ],
    "references": [
      "蒸留計算の基本指標"
    ],
    "function_name": "relative_volatility",
    "keywords": [
      "相対揮発度",
      "蒸留"
    ],
    "interpretation_hint": "alpha が 1 に近いと必要段数や還流比が急に大きくなりやすくなります。"
  },
  {

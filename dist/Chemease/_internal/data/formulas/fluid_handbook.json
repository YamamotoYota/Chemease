[
  {
    "formula_id": "fluid_mass_flux",
    "name_ja": "質量流束",
    "category": "流体",
    "summary": "質量流量と断面積から質量流束を求めます。",
    "description": "質量流量と断面積から質量流束を求めます。 改訂六版 化学工学便覧の流動・移動現象関連節をもとにした便覧レベルの概算式です。",
    "equation_latex": "G = \\\\dot{m} / A",
    "inputs": [
      {
        "key": "mass_flow",
        "label_ja": "質量流量",
        "description": "流れる質量流量",
        "standard_unit": "kg/s",
        "allowed_units": [
          "kg/s",
          "kg/h",
          "t/h"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "area",
        "label_ja": "断面積",
        "description": "流路断面積",
        "standard_unit": "m^2",
        "allowed_units": [
          "m^2",
          "cm^2"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "mass_flux",
        "label_ja": "質量流束",
        "description": "単位断面積当たりの質量流量",
        "standard_unit": "kg/(m^2*s)",
        "allowed_units": [
          "kg/(m^2*s)"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "mass_flow": "質量流量",
      "area": "断面積",
      "mass_flux": "質量流束"
    },
    "applicability": [
      "配管・ダクト・槽内流動の概算",
      "単相流を主対象とした初期検討"
    ],
    "assumptions": [
      "代表値・平均値で評価する",
      "必要に応じて別途詳細な損失係数や圧縮性を考慮する"
    ],
    "cautions": [
      "二相流や脈動流ではそのまま適用しない",
      "極端な条件では詳細相関式で再確認する"
    ],
    "references": [
      "改訂六版 化学工学便覧 第5章 流動",
      "改訂六版 化学工学便覧 第2章 移動現象"
    ],
    "function_name": "fluid_mass_flux",
    "keywords": [
      "質量流束",
      "G"
    ],
    "interpretation_hint": "装置サイズ比較や移動現象相関の前処理に使えます。"
  },

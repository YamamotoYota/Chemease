[
  {
    "formula_id": "heat_thermal_diffusivity",
    "name_ja": "熱拡散率",
    "category": "伝熱",
    "summary": "熱伝導率・密度・比熱から熱拡散率を求めます。",
    "description": "熱伝導率・密度・比熱から熱拡散率を求めます。 改訂六版 化学工学便覧の伝熱・蒸発関連節をもとにした便覧レベルの概算式です。",
    "equation_latex": "\\\\alpha = k /(\\\\rho C_p)",
    "inputs": [
      {
        "key": "thermal_conductivity",
        "label_ja": "熱伝導率",
        "description": "流体または固体の熱伝導率",
        "standard_unit": "W/(m*K)",
        "allowed_units": [
          "W/(m*K)"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "density",
        "label_ja": "密度",
        "description": "密度",
        "standard_unit": "kg/m^3",
        "allowed_units": [
          "kg/m^3",
          "g/cm^3"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "specific_heat",
        "label_ja": "比熱",
        "description": "定圧比熱",
        "standard_unit": "J/(kg*K)",
        "allowed_units": [
          "J/(kg*K)",
          "kJ/(kg*K)"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "thermal_diffusivity",
        "label_ja": "熱拡散率",
        "description": "熱の広がりやすさを示す係数",
        "standard_unit": "m^2/s",
        "allowed_units": [
          "m^2/s"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "thermal_conductivity": "熱伝導率",
      "density": "密度",
      "specific_heat": "比熱",
      "thermal_diffusivity": "熱拡散率"
    },
    "applicability": [
      "伝熱計算の概算",
      "熱交換器・断熱・自然対流の初期検討"
    ],
    "assumptions": [
      "代表物性を用いる",

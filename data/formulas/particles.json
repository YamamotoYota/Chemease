[
  {
    "formula_id": "pt_stokes_settling_velocity",
    "name_ja": "沈降速度（Stokes域）",
    "category": "粉体・機械操作",
    "summary": "微小粒子の終末沈降速度を求めます。",
    "description": "Re が十分小さいStokes域を仮定した基礎式です。粒子分級や沈降の粗い見積りに使います。",
    "equation_latex": "v = g (rho_p - rho_f) d^2 / (18 mu)",
    "inputs": [
      {
        "key": "particle_density",
        "label_ja": "粒子密度",
        "description": "粒子の密度",
        "standard_unit": "kg/m^3",
        "allowed_units": [
          "kg/m^3",
          "g/cm^3"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "fluid_density",
        "label_ja": "流体密度",
        "description": "連続相の密度",
        "standard_unit": "kg/m^3",
        "allowed_units": [
          "kg/m^3",
          "g/cm^3"
        ],
        "positive_only": true,
        "nonzero": true,
        "suggested_property_key": "density"
      },
      {
        "key": "particle_diameter",
        "label_ja": "粒径",
        "description": "粒子代表径",
        "standard_unit": "m",
        "allowed_units": [
          "m",
          "mm",
          "cm"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "viscosity",
        "label_ja": "粘度",
        "description": "流体粘度",
        "standard_unit": "Pas",
        "allowed_units": [
          "Pas",
          "mPas",
          "cP"
        ],
        "positive_only": true,
        "nonzero": true,
        "suggested_property_key": "viscosity"
      }
    ],
    "outputs": [
      {
        "key": "settling_velocity",
        "label_ja": "沈降速度",
        "description": "Stokes域の終末沈降速度",
        "standard_unit": "m/s",
        "allowed_units": [
          "m/s"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "particle_density": "粒子密度 rho_p",
      "fluid_density": "流体密度 rho_f",
      "particle_diameter": "粒径 d",
      "viscosity": "粘度 mu",
      "settling_velocity": "沈降速度 v"
    },
    "applicability": [
      "微小粒子のStokes域"
    ],
    "assumptions": [
      "球形粒子近似",
      "Re が小さい"
    ],
    "cautions": [
      "粗粒子では使えません"
    ],
    "references": [
      "Stokesの式"
    ],
    "function_name": "stokes_settling_velocity",
    "keywords": [
      "沈降",
      "Stokes"
    ],
    "interpretation_hint": "まず結果から Re を逆算し、Stokes域の前提が妥当か確認するのが実務的です。"
  },

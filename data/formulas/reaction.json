    "references": [
      "反応器設計の基本式"
    ],
    "function_name": "residence_time",
    "keywords": [
      "滞留時間"
    ],
    "interpretation_hint": "反応速度定数と掛け合わせると Damkohler 数的な感覚が掴みやすくなります。"

[
  {
    "formula_id": "basic_ideal_gas_moles",
    "name_ja": "理想気体状態方程式",
    "category": "物性・基礎化工計算",
    "summary": "圧力・体積・温度からモル数を求めます。",
    "description": "PV=nRT のうち n を求める基本利用です。ガス量の概算や標準換算の前処理に使えます。",
    "equation_latex": "n = P V / (R T)",
    "inputs": [
      {
        "key": "pressure",
        "label_ja": "圧力",
        "description": "絶対圧で扱う圧力",
        "standard_unit": "Pa",
        "allowed_units": [
          "Pa",
          "kPa",
          "MPa",
          "bar",
          "atm",
          "mmHg",
          "kgf/cm^2G",
          "kgf/cm^2A"
        ],
        "positive_only": true,
        "nonzero": true,
        "pressure_basis_supported": true
      },
      {
        "key": "volume",
        "label_ja": "体積",
        "description": "気体体積",
        "standard_unit": "m^3",
        "allowed_units": [
          "m^3",
          "L",
          "mL"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "temperature",
        "label_ja": "温度",
        "description": "気体温度",
        "standard_unit": "K",
        "allowed_units": [
          "K",
          "degC"
        ],
        "positive_only": true,
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "moles",
        "label_ja": "物質量",
        "description": "理想気体近似の物質量",
        "standard_unit": "mol",
        "allowed_units": [
          "mol",
          "kmol"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "pressure": "圧力 P",
      "volume": "体積 V",
      "temperature": "温度 T",
      "moles": "物質量 n"
    },
    "applicability": [
      "低圧ガスの概算"
    ],
    "assumptions": [
      "理想気体近似"
    ],
    "cautions": [
      "圧力は絶対圧で扱う"
    ],
    "references": [
      "理想気体状態方程式"
    ],
    "function_name": "ideal_gas_moles",
    "keywords": [
      "理想気体",
      "PV=nRT"
    ],
    "interpretation_hint": "高圧や強い非理想性がある場合は圧縮係数や状態方程式拡張が必要です。"
  },

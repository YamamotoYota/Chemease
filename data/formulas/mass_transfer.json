[
  {
    "formula_id": "mass_fick_law",
    "name_ja": "Fickの法則",
    "category": "物質移動",
    "summary": "濃度勾配から拡散モル流束を求めます。",
    "description": "一次元定常拡散の基本式です。符号は高濃度側から低濃度側への移動を表します。",
    "equation_latex": "N = -D dC/dz",
    "inputs": [
      {
        "key": "diffusivity",
        "label_ja": "拡散係数",
        "description": "分子拡散係数",
        "standard_unit": "m^2/s",
        "allowed_units": [
          "m^2/s"
        ],
        "positive_only": true,
        "nonzero": true
      },
      {
        "key": "concentration_gradient",
        "label_ja": "濃度勾配",
        "description": "濃度の空間勾配",
        "standard_unit": "mol/m^4",
        "allowed_units": [
          "mol/m^4"
        ],
        "nonzero": true
      }
    ],
    "outputs": [
      {
        "key": "molar_flux",
        "label_ja": "モル流束",
        "description": "拡散によるモル流束",
        "standard_unit": "mol/(m^2*s)",
        "allowed_units": [
          "mol/(m^2*s)"
        ],
        "required": false
      }
    ],
    "variable_definitions": {
      "diffusivity": "拡散係数 D",
      "concentration_gradient": "濃度勾配 dC/dz",
      "molar_flux": "モル流束 N"
    },
    "applicability": [
      "一次元拡散の概算"
    ],
    "assumptions": [
      "定常・等温近似"
    ],
    "cautions": [
      "対流成分は含みません"
    ],
    "references": [
      "物質移動の基礎式"
    ],
    "function_name": "fick_law",
    "keywords": [
      "Fick",
      "拡散"
    ],
    "interpretation_hint": "負号は濃度降下方向への移動を表すので、絶対値で量を評価する運用もよく行われます。"
  },
